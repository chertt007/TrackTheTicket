# OpenRouter settings (for ai-strategy-service)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_CHEAP=mistralai/mistral-small-3.2-24b-instruct-2506
OPENROUTER_MODEL_CODING=qwen/qwen3-coder-next
OPENROUTER_MODEL_ROBUST=openai/gpt-4o-mini
OPENROUTER_ESCALATE_FAILURE_COUNT=2
OPENROUTER_ESCALATE_CONFIDENCE_THRESHOLD=0.75
# Backward compatibility override (optional)
OPENROUTER_MODEL=

# Monitoring Orchestrator upstream service URLs
FLIGHT_EXTRACTION_URL=http://127.0.0.1:8011
AIRLINE_DISCOVERY_URL=http://127.0.0.1:8012
FAST_PRICE_PROVIDER_URL=http://127.0.0.1:8013
DIRECT_STRATEGY_URL=http://127.0.0.1:8014
BROWSER_AUTOMATION_URL=http://127.0.0.1:8015
NOTIFICATION_SERVICE_URL=http://127.0.0.1:8016
